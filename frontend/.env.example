# TrustFlow Frontend Environment Variables
# Copy to .env.local and fill in values

# Dual-network contract addresses
NEXT_PUBLIC_TRUSTFLOW_MAINNET_ADDRESS=0xB9F38E0180F62e80Be6ca44cE6202316FCcefEC9
NEXT_PUBLIC_QUSDC_MAINNET_ADDRESS=0x3F43DA82eC9A4f5285F10FaF1F26EcA7319E5DA5
NEXT_PUBLIC_TRUSTFLOW_TESTNET_ADDRESS=0xcD0915cb3423F6665C636d723648F78d88B81e52
NEXT_PUBLIC_QUSDC_TESTNET_ADDRESS=0x1850d2a31CB8669Ba757159B638DE19Af532ba5e
NEXT_PUBLIC_DEFAULT_NETWORK=mainnet

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_RELAYER_ADDRESS=your_relayer_address

# Server-side only (never prefix with NEXT_PUBLIC_). Testnet relayer for solo demo.
RELAYER_PRIVATE_KEY=your_relayer_private_key
